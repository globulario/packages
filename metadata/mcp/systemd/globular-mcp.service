[Unit]
Description=Globular MCP Server
After=network-online.target globular-etcd.service
Wants=network-online.target

[Service]
Type=simple
User=globular
Group=globular
WorkingDirectory={{.StateDir}}/mcp
ExecStart={{.Prefix}}/bin/mcp
Restart=on-failure
RestartSec=5
LimitNOFILE=524288
Environment=GLOBULAR_MCP_CONFIG={{.StateDir}}/mcp/config.json
Environment=GLOBULAR_BOOTSTRAP=1

[Install]
WantedBy=multi-user.target
