# Sidekick configuration for MinIO metrics proxy
# This file is read by globular-sidekick.service via EnvironmentFile=

# Listening address for the sidekick proxy (metrics at /.prometheus/metrics)
SIDEKICK_ADDRESS=127.0.0.1:8081

# MinIO backend URL
SIDEKICK_BACKEND=https://127.0.0.1:9000

# Health check path appended to each backend URL
SIDEKICK_HEALTH_PATH=/minio/health/ready

# Health check interval
SIDEKICK_HEALTH_DURATION=10s

# Disable TLS verification for self-signed MinIO certs
SIDEKICK_INSECURE=true
