MINIO_ROOT_USER=globular
MINIO_ROOT_PASSWORD=globularadmin
MINIO_VOLUMES=/var/lib/globular/minio/data

# TLS Configuration - MinIO will use certificates from ${HOME}/.minio/certs
# For 'globular' user, this is /var/lib/globular/.minio/certs
# Certificates must be named: public.crt and private.key
MINIO_CERT_FILE=/var/lib/globular/.minio/certs/public.crt
MINIO_KEY_FILE=/var/lib/globular/.minio/certs/private.key

# Bind addresses (will serve HTTPS when certs are present)
MINIO_OPTS=--address 127.0.0.1:9000 --console-address 127.0.0.1:9001

# Allow unauthenticated access to metrics (scraped by Prometheus via Sidekick)
MINIO_PROMETHEUS_AUTH_TYPE=public
